# Copy this file to .env and fill in all values before running docker compose
# Never commit .env to version control

# ---- JWT ---------------------------------------------------------------
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=replace-with-a-very-long-random-secret-string

# ---- Database ----------------------------------------------------------
DB_PASSWORD=your_postgres_password

# DB_URL is set automatically inside docker-compose (postgres service hostname)
# Override only if connecting to an external database:
# DB_URL=jdbc:postgresql://your-db-host:5432/bountydb

# ---- Redis -------------------------------------------------------------
# REDIS_HOST is set automatically inside docker-compose (redis service hostname)
# Override only if using an external Redis:
# REDIS_HOST=your-redis-host
